<View>
  <!--
    For patterns that are a single object or a small list, not a big Repeater-worthy
    array: notes (project-wide specs), gridline (grid master/companion), unknown
    (cover renders, legends, regulatory text, elevations with no takeoff data), and
    index (sheet table-of-contents lists — small enough to review as one JSON block).

    Freeze-LEFT layout: image column pinned on the left, content scrolls on the right.
    See label-studio-makham-single-freezeR.xml for the mirror (image on the right).
    Uses the Style tag (labelstud.io/tags/style) for the sticky column + row wrappers,
    same convention as label-studio-makham-elements.xml.
  -->
  <Style>
    .stickycol { position:sticky; top:0; flex:1 1 0%; max-width:50%; max-height:96vh; overflow-y:auto; align-self:flex-start; background:white; padding-bottom:8px; padding-right:6px; overflow-wrap:break-word; word-break:break-word; }
    .row-top { display:flex; align-items:flex-start; gap:8px; padding:4px 0; }
    .row { display:flex; align-items:center; gap:8px; padding:2px 0; }
    .hdrbar { display:flex; flex-wrap:wrap; gap:6px 14px; padding-bottom:10px; margin-bottom:12px; border-bottom:1px solid #e5e5e5; }
    .hdrfield { display:flex; flex-direction:column; gap:2px; flex:1 1 130px; min-width:110px; }
  </Style>

  <View style="display:flex; gap:16px; align-items:flex-start;">

    <View className="stickycol">
      <Image name="page" value="$image" zoom="true" zoomControl="true" maxHeight="94vh"/>
    </View>

    <View style="flex:1; min-width:0;">
      <View className="hdrbar">
        <View className="hdrfield">
          <Text name="lbl_house" value="บ้าน" style="font-size:11px; color:#888; font-weight:600;"/>
          <TextArea name="hdr_house" toName="page" value="$house" editable="true" rows="1" style="font-weight:700; font-size:14px; width:100%;"/>
        </View>
        <View className="hdrfield" style="flex:0 1 70px; min-width:60px;">
          <Text name="lbl_png" value="หน้า" style="font-size:11px; color:#888; font-weight:600;"/>
          <TextArea name="hdr_png" toName="page" value="$png" editable="true" rows="1" style="font-weight:700; font-size:14px; width:100%;"/>
        </View>
        <View className="hdrfield" style="flex:0 1 90px; min-width:80px;">
          <Text name="lbl_sheet_code" value="Sheet" style="font-size:11px; color:#888; font-weight:600;"/>
          <TextArea name="hdr_sheet_code" toName="page" value="$sheet_code" editable="true" rows="1" style="font-size:13px; width:100%;"/>
        </View>
        <View className="hdrfield" style="flex:0 1 100px; min-width:90px;">
          <Text name="lbl_pattern" value="Pattern" style="font-size:11px; color:#888; font-weight:600;"/>
          <TextArea name="hdr_pattern" toName="page" value="$pattern" editable="true" rows="1" style="font-size:13px; width:100%;"/>
        </View>
        <View className="hdrfield" style="flex:1 1 200px;">
          <Text name="lbl_sheet_name" value="ชื่อแผ่น" style="font-size:11px; color:#888; font-weight:600;"/>
          <TextArea name="hdr_sheet_name" toName="page" value="$sheet_name" editable="true" rows="1" style="font-size:13px; width:100%;"/>
        </View>
      </View>

      <Header value="เนื้อหาที่ AI สกัดได้ (แก้ JSON ทับได้เลยถ้าจำเป็น)" size="3"/>
      <TextArea
        name="corrected_json"
        toName="page"
        value="$review_json"
        editable="true"
        rows="16"
      />

      <View className="row-top">
        <Text name="lbl_conf" value="File confidence:" style="min-width:200px; font-weight:600; flex-shrink:0;"/>
        <Text name="conf_score_display" value="$file_confidence_score" style="color:#555;"/>
      </View>
      <View className="row-top">
        <Text name="lbl_conf_flags" value="Confidence flags:" style="min-width:200px; font-weight:600; flex-shrink:0;"/>
        <Text name="conf_flags_display" value="$file_confidence_flags" style="color:#555; overflow-wrap:break-word; word-break:break-word; min-width:0;"/>
      </View>
      <View className="row-top">
        <Text name="lbl_warn" value="Warnings ที่ AI เขียนไว้:" style="min-width:200px; font-weight:600; flex-shrink:0;"/>
        <Text name="warn_display" value="$file_warnings" style="color:#555; font-size:12px; overflow-wrap:break-word; word-break:break-word; min-width:0;"/>
      </View>

      <Header value="สถานะการรีวิว" size="4"/>
      <Choices name="review_status" toName="page" choice="single" layout="select">
        <Choice value="approved">✅ ถูกต้อง ไม่ต้องแก้</Choice>
        <Choice value="corrected">✏️ แก้ไขแล้ว (ดู JSON ด้านบน)</Choice>
        <Choice value="reject">❌ ผิดทั้งหมด / ใช้ไม่ได้</Choice>
      </Choices>

      <Header value="หมายเหตุผู้ตรวจ" size="4"/>
      <TextArea
        name="reviewer_note"
        toName="page"
        placeholder="พิมพ์อธิบายเป็นคำพูดปกติ"
        rows="3"
        editable="true"
      />
    </View>

  </View>
</View>
