# training-data/.env.local.example
# Copy this file to training-data/.env.local and fill in real values.
# training-data/.env.local is gitignored — never commit real keys.
#
# Get these from Alibaba Cloud Model Studio console (API Key page).
# QWEN_API_HOST format depends on your workspace/region — see docs/ for details:
#   workspace domain (recommended): https://<WorkspaceId>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
#   legacy domain:                  https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your_api_key_here
QWEN_API_HOST=https://your-workspace-id.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
