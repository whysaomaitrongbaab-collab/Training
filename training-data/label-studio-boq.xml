<View>
  <Header value="BOQ Review — $house / หน้า $page (sheet $sheet_no)" size="2"/>

  <Image name="page" value="$image" zoom="true" zoomControl="true"/>

  <Header value="รายการ BOQ ที่ AI สกัดได้ — แก้ทีละรายการ" size="3"/>

  <Repeater on="$items" indexFlag="{{idx}}">
    <View style="border: 1px solid #ccc; border-radius: 8px; padding: 10px; margin: 8px 0; background: #fafafa;">

      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_category_{{idx}}" value="หมวด:" style="min-width:200px;"/>
        <Text name="category_{{idx}}" value="$items[{{idx}}].category" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_item_no_{{idx}}" value="ลำดับ:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="item_no_{{idx}}" toName="page" value="$items[{{idx}}].item_no" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_description_{{idx}}" value="รายการ:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="description_{{idx}}" toName="page" value="$items[{{idx}}].description" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_quantity_{{idx}}" value="ปริมาณ:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="quantity_{{idx}}" toName="page" value="$items[{{idx}}].quantity" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_unit_{{idx}}" value="หน่วย:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="unit_{{idx}}" toName="page" value="$items[{{idx}}].unit" editable="true" rows="1"/>
      </View>

      <Text name="hdr_ref_{{idx}}" value="ℹ️ ข้อมูลอ้างอิง (ไม่มีกรอบ = ไม่ต้องแก้ตอนนี้ ยังไม่มีข้อมูลราคาจริง)" style="color:#888; font-size:12px; font-weight:600; margin-top:8px;"/>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_mat_unit_price_{{idx}}" value="ราคาวัสดุ/หน่วย:" style="min-width:200px;"/>
        <Text name="material_unit_price_{{idx}}" value="$items[{{idx}}].material_unit_price" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_mat_amount_{{idx}}" value="ยอดวัสดุ:" style="min-width:200px;"/>
        <Text name="material_amount_{{idx}}" value="$items[{{idx}}].material_amount" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_labor_unit_price_{{idx}}" value="ค่าแรง/หน่วย:" style="min-width:200px;"/>
        <Text name="labor_unit_price_{{idx}}" value="$items[{{idx}}].labor_unit_price" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_labor_amount_{{idx}}" value="ยอดค่าแรง:" style="min-width:200px;"/>
        <Text name="labor_amount_{{idx}}" value="$items[{{idx}}].labor_amount" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_total_{{idx}}" value="ยอดรวม:" style="min-width:200px;"/>
        <Text name="total_amount_{{idx}}" value="$items[{{idx}}].total_amount" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_conf_score_{{idx}}" value="AI confidence:" style="min-width:200px;"/>
        <Text name="conf_score_{{idx}}" value="$items[{{idx}}].confidence_score" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_conf_flags_{{idx}}" value="Confidence flags:" style="min-width:200px;"/>
        <Text name="conf_flags_{{idx}}" value="$items[{{idx}}].confidence_flags" style="color:#555;"/>
      </View>

      <View style="display:flex; align-items:center; gap:8px; padding:2px 0; margin-top:8px;">
        <Text name="lbl_delete_{{idx}}" value="สถานะรายการนี้:" style="min-width:200px; font-weight:600;"/>
        <Choices name="delete_{{idx}}" toName="page" showInLine="true">
          <Choice value="delete">❌ ลบรายการนี้ (AI มโน)</Choice>
        </Choices>
      </View>
    </View>
  </Repeater>

  <Header value="หมายเหตุ / รายการที่ AI พลาดไป" size="4"/>
  <TextArea
    name="reviewer_note"
    toName="page"
    placeholder="พิมพ์อธิบายเป็นคำพูดปกติ เช่น 'มีรายการเทคอนกรีตฐานรากที่ AI ไม่เจอ' — ไม่ต้องพิมพ์ JSON"
    rows="3"
    editable="true"
  />
</View>
