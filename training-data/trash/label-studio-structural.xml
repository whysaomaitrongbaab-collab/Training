<View>
  <View style="position: sticky; top: 0; background: white; z-index: 100; padding-bottom: 8px; border-bottom: 2px solid #ccc;">
    <Header value="Structural Review — $house / หน้า $page ($sheet_code $sheet_name)" size="2"/>
    <Image name="page" value="$image" zoom="true" zoomControl="true" maxHeight="380px"/>
  </View>

  <Header value="รายการที่ AI สกัดได้ — แก้ทีละรายการ" size="3"/>

  <Repeater on="$items" indexFlag="{{idx}}">
    <View style="border: 1px solid #ccc; border-radius: 8px; padding: 10px; margin: 8px 0; background: #fafafa;">

      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_element_id_{{idx}}" value="รหัส element:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="element_id_{{idx}}" toName="page" value="$items[{{idx}}].element_id" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_element_type_{{idx}}" value="ประเภท:" style="min-width:200px; font-weight:600;"/>
        <Choices name="element_type_{{idx}}" toName="page" choice="single" layout="select">
          <Choice value="column">เสา</Choice>
          <Choice value="beam">คาน</Choice>
          <Choice value="footing">ฐานราก</Choice>
          <Choice value="slab">พื้น</Choice>
          <Choice value="stair">บันได</Choice>
          <Choice value="other">อื่นๆ</Choice>
        </Choices>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_type_hint_{{idx}}" value="" style="min-width:200px;"/>
        <Text name="type_hint_{{idx}}" value="(AI ทายไว้ว่า: $items[{{idx}}].element_type)" style="font-size:12px; color:#888;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_count_{{idx}}" value="จำนวน:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="count_{{idx}}" toName="page" value="$items[{{idx}}].count" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_grid_refs_{{idx}}" value="ตำแหน่ง grid:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="grid_refs_{{idx}}" toName="page" value="$items[{{idx}}].grid_refs" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_span_{{idx}}" value="ความยาวช่วง (ม.):" style="min-width:200px; font-weight:600;"/>
        <TextArea name="span_length_m_{{idx}}" toName="page" value="$items[{{idx}}].span_length_m" editable="true" rows="1"/>
      </View>

      <Text name="hdr_risky_{{idx}}" value="⚠️ จุดที่ AI มักอ่านผิดบ่อย — เช็คให้ดี" style="color:#b45309; font-size:12px; font-weight:600; margin-top:8px;"/>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_main_dia_{{idx}}" value="ขนาดเหล็กหลัก มม.:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="main_bar_dia_mm_{{idx}}" toName="page" value="$items[{{idx}}].main_bar_dia_mm" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_stirrup_dia_{{idx}}" value="ขนาดปลอก มม.:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="stirrup_dia_mm_{{idx}}" toName="page" value="$items[{{idx}}].stirrup_dia_mm" editable="true" rows="1"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_stirrup_spacing_{{idx}}" value="ระยะห่างปลอก มม.:" style="min-width:200px; font-weight:600;"/>
        <TextArea name="stirrup_spacing_mm_{{idx}}" toName="page" value="$items[{{idx}}].stirrup_spacing_mm" editable="true" rows="1"/>
      </View>

      <Text name="hdr_ref_{{idx}}" value="ℹ️ ข้อมูลอ้างอิง (ไม่มีกรอบ = ไม่ต้องแก้ ปกติ AI ถูก)" style="color:#888; font-size:12px; font-weight:600; margin-top:8px;"/>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_width_{{idx}}" value="ความกว้าง มม.:" style="min-width:200px;"/>
        <Text name="width_mm_{{idx}}" value="$items[{{idx}}].width_mm" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_height_{{idx}}" value="ความสูง มม.:" style="min-width:200px;"/>
        <Text name="height_mm_{{idx}}" value="$items[{{idx}}].height_mm" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_main_count_{{idx}}" value="จำนวนเหล็กหลัก:" style="min-width:200px;"/>
        <Text name="main_bar_count_{{idx}}" value="$items[{{idx}}].main_bar_count" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_main_type_{{idx}}" value="ชนิดเหล็กหลัก:" style="min-width:200px;"/>
        <Text name="main_bar_type_{{idx}}" value="$items[{{idx}}].main_bar_type" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_stirrup_type_{{idx}}" value="ชนิดปลอก:" style="min-width:200px;"/>
        <Text name="stirrup_type_{{idx}}" value="$items[{{idx}}].stirrup_type" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_concrete_{{idx}}" value="กำลังคอนกรีต:" style="min-width:200px;"/>
        <Text name="concrete_grade_{{idx}}" value="$items[{{idx}}].concrete_grade" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_steel_{{idx}}" value="ชั้นเหล็ก:" style="min-width:200px;"/>
        <Text name="steel_grade_{{idx}}" value="$items[{{idx}}].steel_grade" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_conf_score_{{idx}}" value="AI confidence:" style="min-width:200px;"/>
        <Text name="conf_score_{{idx}}" value="$items[{{idx}}].confidence_score" style="color:#555;"/>
      </View>
      <View style="display:flex; align-items:center; gap:8px; padding:2px 0;">
        <Text name="lbl_conf_flags_{{idx}}" value="Confidence flags:" style="min-width:200px;"/>
        <Text name="conf_flags_{{idx}}" value="$items[{{idx}}].confidence_flags" style="color:#555;"/>
      </View>

      <View style="display:flex; align-items:center; gap:8px; padding:2px 0; margin-top:8px;">
        <Text name="lbl_delete_{{idx}}" value="สถานะรายการนี้:" style="min-width:200px; font-weight:600;"/>
        <Choices name="delete_{{idx}}" toName="page" showInLine="true">
          <Choice value="delete">❌ ลบรายการนี้ (AI มโน)</Choice>
        </Choices>
      </View>
    </View>
  </Repeater>

  <Header value="หมายเหตุ / รายการที่ AI พลาดไป" size="4"/>
  <TextArea
    name="reviewer_note"
    toName="page"
    placeholder="พิมพ์อธิบายเป็นคำพูดปกติ เช่น 'มีคาน B6 ที่ AI ไม่เจอ ช่วง grid 3-A ถึง 3-B' — ไม่ต้องพิมพ์ JSON"
    rows="3"
    editable="true"
  />
</View>
